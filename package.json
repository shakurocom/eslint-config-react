  "description": "Shakuro shared ESLint + Prettier config (flat config, ESLint 9/10, React 19, Tailwind v4).",
  "main": "eslint.config.js",
  "exports": {
    ".": "./eslint.config.js",
    "./prettier": "./prettier.config.js"
  },
  "files": [
